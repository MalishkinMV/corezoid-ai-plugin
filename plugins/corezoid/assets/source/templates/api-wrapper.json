              "type": "api_code",
              "lang": "js",
              "src": "var rsp = JSON.parse(JSON.stringify(data));\n\n\ndelete rsp.__callback_url;\n\n\nfunction removeUnderscoreKeys(obj) {\n  for (var key in obj) {\n    if (!obj.hasOwnProperty(key)) continue;\n\n    if (key.startsWith(\"_\")) {\n      delete obj[key];\n    } else if (typeof obj[key] === \"object\" && obj[key] !== null) {\n      removeUnderscoreKeys(obj[key]);\n    }\n  }\n}\n\nremoveUnderscoreKeys(rsp);\n\nfor (let key in data.start_state) {\n  delete rsp[key];\n}\n\ndelete rsp[\"start_state\"];\ndelete data[\"start_state\"];\n\ndata[\"rsp\"] = rsp;\n\n",
              "err_node_id": "68ffba2db677ac4b9f3f535e"
